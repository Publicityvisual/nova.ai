# 🚀 CONFIGURACIÓN NOVA AI
# Copia este archivo a .env y rellena los valores

# =========================================
# 🔑 TOKENS PRINCIPALES (REQUERIDOS)
# =========================================

# Telegram Bot Token (obligatorio)
# Obtener de: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=tu_token_aqui

# OpenRouter API Key (obligatorio para IA avanzada)
# Obtener de: https://openrouter.ai/keys
OPENROUTER_API_KEY=tu_key_aqui

# =========================================
# 📋 CONFIGURACIÓN DEL BOT
# =========================================

# Nombre del bot
BOT_NAME=Sofia

# Número del dueño (WhatsApp con código de país)
OWNER_NUMBER=5215512345670

# Número principal de WhatsApp Business
WHATSAPP_MAIN_NUMBER=5215512345670

# Modo operación: personal, business, enterprise
HUMAN_MODE=enterprise

# =========================================
# ☁️ CONFIGURACIÓN FIREBASE (24/7 GRATIS)
# =========================================

# Firebase Functions - Tu backend 24/7
# No necesitas otros servicios (Render/Railway eliminados)
# Solo Firebase: https://console.firebase.google.com/

# Firebase Config (automático, no necesitas tocar)
# FIREBASE_PROJECT_ID=tu-proyecto-firebase

# Tokens configurables via:
# firebase functions:config:set telegram.token="xxx"
# firebase functions:config:set openrouter.key="xxx"

# =========================================
# 🗑️ SERVICIOS ELIMINADOS (YA NO SE USAN)
# =========================================

# ❌ RAILWAY - Eliminado completamente
# ❌ RENDER - Eliminado completamente
# ❌ CLOUDFLARE WORKERS - Eliminado (usamos Firebase ahora)
# 
# Ver guía: ELIMINAR-TODA-LA-NUBE.md
# Solo queda: Firebase (24/7 gratis) + Local (tu PC)

# =========================================
# 🤖 MODELOS DE IA ADICIONALES (OPCIONAL)
# =========================================

# Gemini API (opcional)
# GEMINI_API_KEY=tu_key_gemini

# Groq API (opcional, muy rápido)
# GROQ_API_KEY=tu_key_groq

# Anthropic (NO recomendado, usamos NOVA)
# ANTHROPIC_API_KEY=no_necesario

# =========================================
# 🔧 CONFIGURACIÓN AVANZADA
# =========================================

# Puerto del servidor (default: 3000)
PORT=3000

# Entorno: development, production
NODE_ENV=production

# Debug mode: true, false
DEBUG=false

# Auto-commit a GitHub: true, false
AUTO_COMMIT=true

# Intervalo de sync (minutos)
SYNC_INTERVAL=10

# =========================================
# 🛡️ SEGURIDAD
# =========================================

# Admin code para Telegram
TELEGRAM_ADMIN_CODE=sofia-admin-2025

# Código de acceso a función secreta
EVA_MASTER_CODE=eva-master-2025

# =========================================
# 🎯 FEATURES
# =========================================

# Activar modo sin censura: true, false
UNCENSORED_MODE=true

# Activar modo proactivo: true, false
PROACTIVE_MODE=true

# Activar anti-ban: true, false
ANTI_BAN=true

# Activar auto-repair: true, false
AUTO_REPAIR=true
