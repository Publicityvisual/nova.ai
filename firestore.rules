rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Tenants: only admin SDK (Cloud Functions) can write
    match /tenants/{tenantId} {
      allow read: if false;
      allow write: if false;

      // Conversations under each tenant
      match /conversations/{contactId} {
        allow read: if false;
        allow write: if false;

        match /messages/{messageId} {
          allow read: if false;
          allow write: if false;
        }
      }
    }

    // Block everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
