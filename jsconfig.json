{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "checkJs": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@core/*": [
        "src/core/*"
      ],
      "@telegram/*": [
        "src/telegram/*"
      ],
      "@utils/*": [
        "src/utils/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "scripts/**/*",
    "skills/**/*",
    "adapters/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "data",
    "logs"
  ]
}